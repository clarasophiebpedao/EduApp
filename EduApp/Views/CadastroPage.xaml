<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EduApp.Views.CadastroPage"
             BackgroundColor="{StaticResource Background}">

	<VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

		<Label Text="Bem Vindo!" FontSize="28" FontAttributes="Bold" TextColor="#101213" />
		<Label Text="Crie sua conta" TextColor="#57636C" Margin="0,0,0,10" />

		<Border>
			<Entry x:Name="EmailEntry" Placeholder="E-mail" Keyboard="Email" />
		</Border>

		<Border>
			<Entry x:Name="SenhaEntry" Placeholder="Senha" IsPassword="True" />
		</Border>

		<Border>
			<Entry x:Name="ConfirmarSenhaEntry" Placeholder="Confirmar Senha" IsPassword="True" />
		</Border>

		<Button Text="Criar Conta" Clicked="OnFinalizarCadastro" />

		<Button Text="Já tem conta? Login"
			BackgroundColor="Transparent"
			TextColor="#4B39EF"
			Clicked="OnIrParaLogin" />	

	</VerticalStackLayout>
</ContentPage>